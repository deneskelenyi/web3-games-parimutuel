# Example environment file.
# Copy to .env and fill in your own values.
# NEVER commit .env to git.

# Deployer / owner private key (used by forge script and local anvil deploys)
PRIVATE_KEY=0x...

# Base Sepolia RPC (only needed for testnet deploys)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Bot private key (only needed to run bot/test_bot.py)
BOT_PRIVATE_KEY=0x...
